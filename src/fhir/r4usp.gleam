  let Extension(id:, url:, ext:) = extension
  let fields = [#("url", json.string(url))]
  let fields = case id {
    Some(v) -> [#("id", json.string(v)), ..fields]
    None -> fields
  }
  let fields = [ext_simple_or_complex_to_json(ext), ..fields]
  json.object(fields)
