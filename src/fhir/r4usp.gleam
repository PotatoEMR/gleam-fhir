  }
  let fields = case id {
    Some(v) -> [#("id", json.string(v)), ..fields]
    None -> fields
  }
  let fields = [
    #("resourceType", json.string("ChargeItemDefinition")),
    ..fields
  ]
  json.object(fields)
}

