pub fn patient_to_json(patient: Patient) -> Json {
  let Patient(
    link:,
    managing_organization:,
    general_practitioner:,
    communication:,
    contact:,
    photo:,
    multiple_birth:,
    marital_status:,
    address:,
    deceased:,
    birth_date:,
    gender:,
    telecom:,
    name:,
    active:,
    identifier:,
    modifier_extension:,
    extension:,
    contained:,
    text:,
    language:,
    implicit_rules:,
    meta:,
    id:,
    us_core_ethnicity:,
    us_core_individual_sex:,
    individual_recorded_sex_or_gender:,
    us_core_birthsex:,
    us_core_sex:,
    us_core_race:,
    us_core_interpreter_needed:,
    us_core_gender_identity:,
    us_core_tribal_affiliation:,
  ) = patient
  let fields = []
  let extension =
    list.flatten([
      extension,
      list.map(us_core_ethnicity, us_core_ethnicity_to_ext),
      list.map(us_core_individual_sex, us_core_individual_sex_to_ext),
      list.map(
        individual_recorded_sex_or_gender,
        individual_recordedsexorgender_to_ext,
      ),
      list.map(us_core_birthsex, us_core_birthsex_to_ext),
      list.map(us_core_sex, us_core_sex_to_ext),
      list.map(us_core_race, us_core_race_to_ext),
      list.map(us_core_interpreter_needed, us_core_interpreter_needed_to_ext),
      list.map(us_core_gender_identity, us_core_genderidentity_to_ext),
      list.map(us_core_tribal_affiliation, us_core_tribal_affiliation_to_ext),
    ])
  let fields = case link {
    [] -> fields
    _ -> [#("link", json.array(link, patient_link_to_json)), ..fields]
  }
  let fields = case managing_organization {
    Some(v) -> [#("managingOrganization", reference_to_json(v)), ..fields]
    None -> fields
  }
  let fields = case general_practitioner {
    [] -> fields
    _ -> [
      #(
        "generalPractitioner",
        json.array(general_practitioner, reference_to_json),
      ),
      ..fields
    ]
  }
  let fields = case communication {
    [] -> fields
    _ -> [
      #(
        "communication",
        json.array(communication, patient_communication_to_json),
      ),
      ..fields
    ]
  }
  let fields = case contact {
    [] -> fields
    _ -> [#("contact", json.array(contact, patient_contact_to_json)), ..fields]
  }
  let fields = case photo {
    [] -> fields
    _ -> [#("photo", json.array(photo, attachment_to_json)), ..fields]
  }
  let fields = case multiple_birth {
    Some(v) -> [
      #(
        "multipleBirth"
          <> case v {
          PatientMultiplebirthBoolean(_) -> "Boolean"
          PatientMultiplebirthInteger(_) -> "Integer"
        },
        patient_multiplebirth_to_json(v),
      ),
      ..fields
    ]
    None -> fields
  }
  let fields = case marital_status {
    Some(v) -> [#("maritalStatus", codeableconcept_to_json(v)), ..fields]
    None -> fields
  }
  let fields = case address {
    [] -> fields
    _ -> [#("address", json.array(address, address_to_json)), ..fields]
  }
  let fields = case deceased {
    Some(v) -> [
      #(
        "deceased"
          <> case v {
          PatientDeceasedBoolean(_) -> "Boolean"
          PatientDeceasedDatetime(_) -> "DateTime"
        },
        patient_deceased_to_json(v),
      ),
      ..fields
    ]
    None -> fields
  }
  let fields =
    primitive_to_json(fields, birth_date, pt.date_to_json, "birthDate")
  let fields =
    primitive_to_json(
      fields,
      gender,
      r4usp_valuesets.administrativegender_to_json,
      "gender",
    )
  let fields = case telecom {
    [] -> fields
    _ -> [#("telecom", json.array(telecom, contactpoint_to_json)), ..fields]
  }
  let fields = case name {
    [] -> fields
    _ -> [#("name", json.array(name, humanname_to_json)), ..fields]
  }
  let fields = primitive_to_json(fields, active, json.bool, "active")
  let fields = case identifier {
    [] -> fields
    _ -> [#("identifier", json.array(identifier, identifier_to_json)), ..fields]
  }
  let fields = case modifier_extension {
    [] -> fields
    _ -> [
      #("modifierExtension", json.array(modifier_extension, extension_to_json)),
      ..fields
    ]
  }
  let fields = case extension {
    [] -> fields
    _ -> [#("extension", json.array(extension, extension_to_json)), ..fields]
  }
  let fields = case contained {
    [] -> fields
    _ -> [#("contained", json.array(contained, resource_to_json)), ..fields]
  }
  let fields = case text {
    Some(v) -> [#("text", narrative_to_json(v)), ..fields]
    None -> fields
  }
  let fields = primitive_to_json(fields, language, json.string, "language")
  let fields =
    primitive_to_json(fields, implicit_rules, json.string, "implicitRules")
  let fields = case meta {
    Some(v) -> [#("meta", meta_to_json(v)), ..fields]
    None -> fields
  }
  let fields = case id {
    Some(v) -> [#("id", json.string(v)), ..fields]
    None -> fields
  }
  let fields = [#("resourceType", json.string("Patient")), ..fields]
  json.object(fields)
}

pub fn patient_decoder() -> Decoder(Patient) {
  use <- decode.recursive
  use link <- decode.optional_field(
    "link",
    [],
    decode.list(patient_link_decoder()),
  )
  use managing_organization <- decode.optional_field(
    "managingOrganization",
    None,
    decode.optional(reference_decoder()),
  )
  use general_practitioner <- decode.optional_field(
    "generalPractitioner",
    [],
    decode.list(reference_decoder()),
  )
  use communication <- decode.optional_field(
    "communication",
    [],
    decode.list(patient_communication_decoder()),
  )
  use contact <- decode.optional_field(
    "contact",
    [],
    decode.list(patient_contact_decoder()),
  )
  use photo <- decode.optional_field(
    "photo",
    [],
    decode.list(attachment_decoder()),
  )
  use multiple_birth <- decode.then(
    none_if_omitted(patient_multiplebirth_decoder()),
  )
  use marital_status <- decode.optional_field(
    "maritalStatus",
    None,
    decode.optional(codeableconcept_decoder()),
  )
  use address <- decode.optional_field(
    "address",
    [],
    decode.list(address_decoder()),
  )
  use deceased <- decode.then(none_if_omitted(patient_deceased_decoder()))
  use birth_date <- primitive_decoder("birthDate", pt.date_decoder())
  use gender <- primitive_decoder(
    "gender",
    r4usp_valuesets.administrativegender_decoder(),
  )
  use telecom <- decode.optional_field(
    "telecom",
    [],
    decode.list(contactpoint_decoder()),
  )
  use name <- decode.optional_field(
    "name",
    [],
    decode.list(humanname_decoder()),
  )
  use active <- primitive_decoder("active", decode.bool)
  use identifier <- decode.optional_field(
    "identifier",
    [],
    decode.list(identifier_decoder()),
  )
  use modifier_extension <- decode.optional_field(
    "modifierExtension",
    [],
    decode.list(extension_decoder()),
  )
  use extension <- decode.optional_field(
    "extension",
    [],
    decode.list(extension_decoder()),
  )
  use contained <- decode.optional_field(
    "contained",
    [],
    decode.list(resource_decoder()),
  )
  use text <- decode.optional_field(
    "text",
    None,
    decode.optional(narrative_decoder()),
  )
  use language <- primitive_decoder("language", decode.string)
  use implicit_rules <- primitive_decoder("implicitRules", decode.string)
  use meta <- decode.optional_field(
    "meta",
    None,
    decode.optional(meta_decoder()),
  )
  use id <- decode.optional_field("id", None, decode.optional(decode.string))
  let #(
    us_core_ethnicity_,
    us_core_individual_sex_,
    individual_recorded_sex_or_gender_,
    us_core_birthsex_,
    us_core_sex_,
    us_core_race_,
    us_core_interpreter_needed_,
    us_core_gender_identity_,
    us_core_tribal_affiliation_,
    extension,
  ) =
    list.fold(
      from: #([], [], [], [], [], [], [], [], [], []),
      over: extension,
      with: fn(acc, ext) {
        let #(a0, a1, a2, a3, a4, a5, a6, a7, a8, plain) = acc
        case us_core_ethnicity_from_ext(ext) {
          Ok(v) -> #([v, ..a0], a1, a2, a3, a4, a5, a6, a7, a8, plain)
          Error(_) ->
            case us_core_individual_sex_from_ext(ext) {
              Ok(v) -> #(a0, [v, ..a1], a2, a3, a4, a5, a6, a7, a8, plain)
              Error(_) ->
                case individual_recordedsexorgender_from_ext(ext) {
                  Ok(v) -> #(a0, a1, [v, ..a2], a3, a4, a5, a6, a7, a8, plain)
                  Error(_) ->
                    case us_core_birthsex_from_ext(ext) {
                      Ok(v) -> #(
                        a0,
                        a1,
                        a2,
                        [v, ..a3],
                        a4,
                        a5,
                        a6,
                        a7,
                        a8,
                        plain,
                      )
                      Error(_) ->
                        case us_core_sex_from_ext(ext) {
                          Ok(v) -> #(
                            a0,
                            a1,
                            a2,
                            a3,
                            [v, ..a4],
                            a5,
                            a6,
                            a7,
                            a8,
                            plain,
                          )
                          Error(_) ->
                            case us_core_race_from_ext(ext) {
                              Ok(v) -> #(
                                a0,
                                a1,
                                a2,
                                a3,
                                a4,
                                [v, ..a5],
                                a6,
                                a7,
                                a8,
                                plain,
                              )
                              Error(_) ->
                                case us_core_interpreter_needed_from_ext(ext) {
                                  Ok(v) -> #(
                                    a0,
                                    a1,
                                    a2,
                                    a3,
                                    a4,
                                    a5,
                                    [v, ..a6],
                                    a7,
                                    a8,
                                    plain,
                                  )
                                  Error(_) ->
                                    case us_core_genderidentity_from_ext(ext) {
                                      Ok(v) -> #(
                                        a0,
                                        a1,
                                        a2,
                                        a3,
                                        a4,
                                        a5,
                                        a6,
                                        [v, ..a7],
                                        a8,
                                        plain,
                                      )
                                      Error(_) ->
                                        case
                                          us_core_tribal_affiliation_from_ext(
                                            ext,
                                          )
                                        {
                                          Ok(v) -> #(
                                            a0,
                                            a1,
                                            a2,
                                            a3,
                                            a4,
                                            a5,
                                            a6,
                                            a7,
                                            [v, ..a8],
                                            plain,
                                          )
                                          Error(_) -> #(
                                            a0,
                                            a1,
                                            a2,
                                            a3,
                                            a4,
                                            a5,
                                            a6,
                                            a7,
                                            a8,
                                            [ext, ..plain],
                                          )
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
      },
    )
  let us_core_ethnicity = us_core_ethnicity_
  let us_core_individual_sex = us_core_individual_sex_
  let individual_recorded_sex_or_gender = individual_recorded_sex_or_gender_
  let us_core_birthsex = us_core_birthsex_
  let us_core_sex = us_core_sex_
  let us_core_race = us_core_race_
  let us_core_interpreter_needed = us_core_interpreter_needed_
  let us_core_gender_identity = us_core_gender_identity_
  let us_core_tribal_affiliation = us_core_tribal_affiliation_

  use rt <- decode.field("resourceType", decode.string)
  use <- bool.guard(
    rt != "Patient",
    decode.failure(patient_new(), "resourceType"),
  )
  decode.success(Patient(
    link:,
    managing_organization:,
    general_practitioner:,
    communication:,
    contact:,
    photo:,
    multiple_birth:,
    marital_status:,
    address:,
    deceased:,
    birth_date:,
    gender:,
    telecom:,
    name:,
    active:,
    identifier:,
    modifier_extension:,
    extension:,
    contained:,
    text:,
    language:,
    implicit_rules:,
    meta:,
    id:,
    us_core_ethnicity:,
    us_core_individual_sex:,
    individual_recorded_sex_or_gender:,
    us_core_birthsex:,
    us_core_sex:,
    us_core_race:,
    us_core_interpreter_needed:,
    us_core_gender_identity:,
    us_core_tribal_affiliation:,
  ))
}

